<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss} %-5p %m%n</Property>
    </Properties>

    <Appenders>
        <Console name="console" target="SYSTEM_OUT" follow="true">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <RollingFile name="file"
                     fileName="logs/selenium.log"
                     filePattern="logs/selenium.log.%d{yyyy-MM-dd}">
            <PatternLayout pattern="${LOG_PATTERN}"/>

            <!-- TimeBasedTriggeringPolicy handles the daily rollover -->
            <TimeBasedTriggeringPolicy interval="1" modulate="true"/>

            <!-- Keep logs for 30 days (optional, adjust as needed) -->
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="console" level="${sys:consoleLogging:-info}"/>
            <AppenderRef ref="file" level="${sys:fileLogging:-info}"/>
        </Root>
    </Loggers>
</Configuration>